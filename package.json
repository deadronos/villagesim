{
  "name": "villagesim",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first VillageSim starter built with Next.js, React, and TypeScript.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "planner:service:build": "npm --prefix services/planner run build",
    "planner:service:dev": "npm --prefix services/planner run dev",
    "planner:service:start": "npm --prefix services/planner run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/component",
    "tick:mock": "tsx workers/tick.ts"
  },
  "dependencies": {
    "@github/copilot": "1.0.11",
    "@github/copilot-sdk": "0.2.0",
    "convex": "^1.34.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
