# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TOWN_ID=demo-town

# GitHub OAuth (optional for the starter)
GITHUB_CLIENT_ID=github_oauth_client_id
GITHUB_CLIENT_SECRET=github_oauth_client_secret
APPROVED_GITHUB_LOGINS=deadronos

# Convex / authoritative state
VILLAGESIM_STATE_MODE=mock
CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_ADMIN_KEY=convex_admin_key_for_local_worker

# Planner / local-first mode
# Leave VILLAGESIM_PLANNER_MOCK=true for first-run local development.
# When you wire a hosted planner service, set the service URL/token and optionally
# add the signing secret used for request verification on the planner-service side.
VILLAGESIM_PLANNER_SERVICE_URL=http://localhost:4000/plan
VILLAGESIM_PLANNER_SERVICE_TOKEN=planner-service-token
VILLAGESIM_PLANNER_SERVICE_SIGNING_SECRET=planner-service-signing-secret
VILLAGESIM_PLANNER_SERVICE_TIMEOUT_MS=3000
VILLAGESIM_PLANNER_MOCK=true
VILLAGESIM_PLANNER_BUDGET_PER_TICK=2
VILLAGESIM_PLANNER_DRAIN_PER_DISPATCH=4

# Planner service runtime provider (mock | copilot)
VILLAGESIM_PLANNER_SERVICE_PROVIDER=mock
VILLAGESIM_PLANNER_COPILOT_MODEL=gpt-5
VILLAGESIM_PLANNER_COPILOT_TIMEOUT_MS=45000
# Optional overrides when using the Copilot-backed planner provider locally
VILLAGESIM_PLANNER_COPILOT_CLI_PATH=
VILLAGESIM_PLANNER_COPILOT_CLI_URL=
VILLAGESIM_PLANNER_COPILOT_WORKING_DIRECTORY=

# Session / security
SESSION_SECRET=replace-with-a-local-dev-secret
