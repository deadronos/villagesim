# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TOWN_ID=demo-town

# GitHub OAuth (optional in local mock mode, required for hosted sign-in)
GITHUB_CLIENT_ID=github_oauth_client_id
GITHUB_CLIENT_SECRET=github_oauth_client_secret
APPROVED_GITHUB_LOGINS=deadronos

# Convex / authoritative state
# Leave VILLAGESIM_STATE_MODE=mock for the default starter flow.
# Switch to convex only after you have a real deployment URL and admin key.
VILLAGESIM_STATE_MODE=mock
CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_ADMIN_KEY=convex_admin_key_for_local_worker

# Planner request settings consumed by the Next.js app
# Leave VILLAGESIM_PLANNER_MOCK=true for first-run local development.
# When you wire a planner service, point the URL at either a local service instance
# or a private-alpha Funnel URL, then set the shared token and signing secret.
# App-side planner requests use a strict timeout and fall back to the deterministic
# mock planner if the service is unavailable or returns a non-retryable failure.
VILLAGESIM_PLANNER_SERVICE_URL=http://localhost:4000/plan
VILLAGESIM_PLANNER_SERVICE_TOKEN=planner-service-token
VILLAGESIM_PLANNER_SERVICE_SIGNING_SECRET=planner-service-signing-secret
VILLAGESIM_PLANNER_SERVICE_TIMEOUT_MS=3000
VILLAGESIM_PLANNER_MOCK=true
VILLAGESIM_PLANNER_BUDGET_PER_TICK=2
VILLAGESIM_PLANNER_DRAIN_PER_DISPATCH=4

# Planner service runtime settings
# The service auto-loads repo-root .env and .env.local when you run it from this workspace.
# Export these into your shell, container, or host environment to override values.
VILLAGESIM_PLANNER_SERVICE_HOST=0.0.0.0
VILLAGESIM_PLANNER_SERVICE_PORT=4000
VILLAGESIM_PLANNER_SERVICE_MAX_BODY_BYTES=16384
VILLAGESIM_PLANNER_SERVICE_RATE_LIMIT_MAX=30
VILLAGESIM_PLANNER_SERVICE_RATE_LIMIT_WINDOW_MS=60000
VILLAGESIM_PLANNER_SERVICE_REPLAY_WINDOW_MS=300000

# Planner service runtime provider (mock | copilot)
VILLAGESIM_PLANNER_SERVICE_PROVIDER=mock
VILLAGESIM_PLANNER_COPILOT_MODEL=gpt-5-mini
VILLAGESIM_PLANNER_COPILOT_TIMEOUT_MS=45000
# Optional overrides when using the Copilot-backed planner provider locally
VILLAGESIM_PLANNER_COPILOT_CLI_PATH=
VILLAGESIM_PLANNER_COPILOT_CLI_URL=
VILLAGESIM_PLANNER_COPILOT_CONFIG_DIR=
VILLAGESIM_PLANNER_COPILOT_WORKING_DIRECTORY=
VILLAGESIM_PLANNER_COPILOT_REASONING_EFFORT=
VILLAGESIM_PLANNER_COPILOT_LOG_LEVEL=error

# Session / security
SESSION_SECRET=replace-with-a-local-dev-secret
